{
  "name": "siteforge",
  "version": "0.0.2",
  "description": "Build a per-site CLI + MCP server from any website. Proactive exploration, state-graph cache, deterministic replay with self-heal.",
  "license": "MIT",
  "author": "Varad Thokal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "siteforge": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "selfcheck": "tsx examples/self-check.ts",
    "snapshotcheck": "tsx examples/snapshot-self-check.ts",
    "storagecheck": "tsx examples/storage-self-check.ts",
    "map": "tsx examples/map-instagram.ts",
    "probe": "tsx examples/probe-instagram.ts",
    "test": "npm run selfcheck && npm run snapshotcheck && npm run storagecheck"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "graphology": "^0.25.0",
    "graphology-communities-louvain": "^2.0.0",
    "playwright": "^1.50.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai-agent",
    "browser-automation",
    "mcp",
    "playwright",
    "stagehand",
    "site-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/varadfromeast/siteforge.git"
  }
}
